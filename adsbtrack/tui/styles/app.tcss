/* adsbtrack TUI styles
 * Screen-level and table-level rules only; individual chrome widgets
 * (StatusStrip, Sidebar, PageHeader, FilterBar, ActionBar, Card) carry
 * their own DEFAULT_CSS in adsbtrack/tui/widgets.py so a rule in two
 * places doesn't silently fight itself.
 *
 * Keep the palette here in lockstep with design/colors_and_type.css.
 */

Screen {
    background: #0b0f14;
    color: #e4ecf3;
}

#app-row {
    height: 1fr;
}

#content {
    width: 1fr;
    height: 1fr;
}

ContentSwitcher {
    height: 1fr;
}

/* Views (each is a Vertical subclass in adsbtrack/tui/views/). */

.view {
    height: 1fr;
}

/* Tables */

DataTable {
    background: #0b0f14;
    color: #e4ecf3;
    height: 1fr;
}

DataTable > .datatable--header {
    background: #141b23;
    color: #6b7885;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #102b37;
    color: #e4ecf3;
    text-style: bold;
}

DataTable > .datatable--hover {
    background: #141a22;
}

DataTable > .datatable--odd-row {
    background: #0b0f14;
}

DataTable > .datatable--even-row {
    background: #0e131a;
}

/* Spoof inline detail panel (violet left border, bg-1). */

.spoof-detail {
    height: auto;
    max-height: 16;
    background: #141b23;
    color: #aab6c2;
    border-left: thick #c24bd6;
    padding: 1 2;
    margin: 0 1 1 1;
}

/* Ops view: grid of cards, one input field across the top. */

#ops-input {
    background: #0b0f14;
    color: #e4ecf3;
    border: solid #222c37;
    padding: 0 1;
    height: 1;
    margin: 1 1 0 1;
}

#ops-suggestions {
    margin: 0 1;
    color: #6b7885;
    height: auto;
}

#ops-grid {
    grid-size: 2 1;
    grid-gutter: 1 1;
    padding: 1 1;
    height: auto;
}

/* Status dashboard grid. */

#status-grid {
    grid-size: 4;
    grid-gutter: 1 1;
    padding: 1 1;
    height: 1fr;
    overflow-y: auto;
}

/* Map view: canvas and HUD strip styling lives inline in
 * adsbtrack/tui/views/map.py on MapCanvas, _HudRow, and _HudLabel.
 * The layout is a plain Vertical of PageHeader / _HudRow(top) / canvas /
 * _HudRow(bottom); no docking or CSS layers are involved.
 */

/* Jump-to-hex modal. */

JumpToHex {
    align: center top;
}

#jump-dialog {
    width: 60%;
    min-width: 48;
    max-width: 96;
    height: auto;
    background: #141b23;
    border: solid #2d3946;
    padding: 0;
    margin-top: 6;
}

#jump-dialog > .jump-title {
    height: 1;
    background: #141b23;
    color: #6b7885;
    padding: 0 1;
    border-bottom: solid #222c37;
}

#jump-dialog > Input {
    background: #141b23;
    color: #e4ecf3;
    border: none;
    padding: 0 1;
}

#jump-dialog > DataTable {
    height: auto;
    max-height: 12;
    background: #141b23;
    border-top: solid #222c37;
}

/* Help overlay. */

HelpScreen {
    align: center middle;
}

#help-dialog {
    width: 60%;
    min-width: 48;
    max-width: 96;
    height: auto;
    background: #141b23;
    border: solid #2d3946;
    padding: 1 2;
    color: #aab6c2;
}
